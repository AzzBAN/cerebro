# =============================================================================
# Project Cerebro — Secrets Configuration Example
# =============================================================================
# Copy this file to configs/secrets.env and fill in real values.
# NEVER commit secrets.env to version control.
#
# Single-broker architecture: ALL trading (Crypto Spot + Futures + Gold XAUUSDT)
# runs through Binance. No secondary broker credentials are required.
# =============================================================================

# =============================================================================
# ENVIRONMENT SAFETY FLAG
# Must match the CLI flag (--paper / --demo / --live) AND app.yaml environment.
# Mismatch causes immediate startup failure — no silent overrides.
#   paper  → offline, synthetic prices, no API keys required
#   demo   → demo.binance.com, real live prices, virtual execution, zero risk
#   live   → Binance mainnet, real funds
# =============================================================================
ENVIRONMENT=paper

# =============================================================================
# BROKER — BINANCE (Crypto Spot + USDT-M Futures · includes Gold XAUUSDT)
# =============================================================================

# --- Spot (BTC, ETH, SOL, etc.) ---
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Spot testnet (optional — for smoke-testing the live wiring against testnet.binance.vision)
BINANCE_TESTNET_API_KEY=
BINANCE_TESTNET_API_SECRET=

# --- Binance Demo Trading (ENVIRONMENT=demo) ---------------------------------
# Real live prices via mainnet WebSocket. Orders route to a virtual matching
# engine — zero financial risk. Register at https://demo.binance.com
# REST endpoint: https://demo-api.binance.vision
BINANCE_DEMO_API_KEY=
BINANCE_DEMO_API_SECRET=

# Futures demo (optional — only needed when markets.yaml contains futures symbols)
# REST endpoint: https://demo-dapi.binance.vision
BINANCE_DEMO_FUTURES_API_KEY=
BINANCE_DEMO_FUTURES_API_SECRET=

# --- USDT-M Futures (XAUUSDT Gold + BTC/ETH perps) ---
# Required when any symbol in markets.yaml has contract_type: futures_perpetual
BINANCE_FUTURES_API_KEY=
BINANCE_FUTURES_API_SECRET=

# Futures testnet (optional live smoke test)
# Sign up at https://testnet.binancefuture.com
BINANCE_FUTURES_TESTNET_API_KEY=
BINANCE_FUTURES_TESTNET_API_SECRET=

# =============================================================================
# DATABASE — PostgreSQL / Supabase
# =============================================================================
DATABASE_URL=postgresql://cerebro:changeme@localhost:5432/cerebro

# Supabase-specific (if using managed Supabase instead of self-hosted Postgres)
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# =============================================================================
# CACHE — Redis
# =============================================================================
REDIS_URL=redis://localhost:6379/0
# REDIS_URL=rediss://:password@host:6380/0       # TLS (production)


# =============================================================================
# MARKET DATA — COINGLASS (Derivatives Intelligence)
# Register at https://www.coinglass.com/pricing  (free tier sufficient)
# Used by: ingest/coinglass/ — OI, Funding Rate, Long/Short Ratio, Liquidations,
#          CVD, Taker Volume, Fear & Greed Index, Coinbase Premium, Futures Basis
# Header sent with every request: CG-API-KEY: <value>
# =============================================================================
COINGLASS_API_KEY=

# =============================================================================
# MARKET DATA — FINNHUB (Economic Calendar)
# Free tier: 60 calls/minute. Register at https://finnhub.io/register
# =============================================================================
FINNHUB_API_KEY=
# =============================================================================
# LLM PROVIDERS
# At least one provider is required. Cerebro tries them in the order defined
# in app.yaml agent.llm.providers.
# =============================================================================

# Google Gemini — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Anthropic Claude — https://console.anthropic.com
ANTHROPIC_API_KEY=
# Override base URL for Anthropic-compatible providers (OpenRouter, AWS Bedrock, etc.)
# Leave empty for the default Anthropic endpoint.
# ANTHROPIC_BASE_URL=https://openrouter.ai/api/v1/anthropic/messages

# OpenAI (or any OpenAI-compatible endpoint, e.g. LM Studio / Ollama)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_BASE_URL=http://localhost:11434/v1      # Ollama local

# =============================================================================
# CHATOPS — TELEGRAM
# =============================================================================
TELEGRAM_BOT_TOKEN=

# Comma-separated Telegram user IDs allowed to issue commands.
# Get your ID via @userinfobot on Telegram.
TELEGRAM_ALLOWLIST_USER_IDS=

# =============================================================================
# CHATOPS — DISCORD
# =============================================================================
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=

# Channel IDs — right-click channel → Copy ID (Developer Mode required)
DISCORD_TRADE_CHANNEL_ID=
DISCORD_AI_REASONING_CHANNEL_ID=
DISCORD_SYSTEM_ALERTS_CHANNEL_ID=
