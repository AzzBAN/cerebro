# =============================================================================
# Project Cerebro — Markets Configuration Example
# =============================================================================
# Copy this file to configs/markets.yaml and adjust to your trading universe.
# Symbols must use Cerebro's canonical internal format:
#   Spot             -> BTC/USDT
#   Futures perpetual-> BTC/USDT-PERP
# =============================================================================

venues:
  - venue: binance_spot
    symbols:
      - symbol: BTC/USDT
        contract_type: spot
        leverage: 1
        margin_type: isolated
        tick_size: 0.01
        lot_size: 0.00001
        min_notional: 5.0
        max_order_notional: 100000.0
        max_position_size_pct: 5.0
        timeframes: [1m, 5m, 15m, 1h]
        primary_timeframe: 5m
        trend_timeframe: 1h
        max_spread_pct: 0.05
        enabled: true

      - symbol: ETH/USDT
        contract_type: spot
        leverage: 1
        margin_type: isolated
        tick_size: 0.01
        lot_size: 0.0001
        min_notional: 5.0
        max_order_notional: 50000.0
        max_position_size_pct: 5.0
        timeframes: [1m, 5m, 15m, 1h]
        primary_timeframe: 5m
        trend_timeframe: 1h
        max_spread_pct: 0.05
        enabled: true

      - symbol: SOL/USDT
        contract_type: spot
        leverage: 1
        margin_type: isolated
        tick_size: 0.01
        lot_size: 0.01
        min_notional: 5.0
        max_order_notional: 20000.0
        max_position_size_pct: 3.0
        timeframes: [1m, 5m, 15m, 1h]
        primary_timeframe: 5m
        trend_timeframe: 1h
        max_spread_pct: 0.1
        enabled: true

  - venue: binance_futures
    symbols:
      - symbol: BTC/USDT-PERP
        contract_type: futures_perpetual
        leverage: 5
        margin_type: isolated
        tick_size: 0.10
        lot_size: 0.001
        min_notional: 5.0
        max_order_notional: 50000.0
        max_position_size_pct: 3.0
        timeframes: [1m, 5m, 15m, 1h]
        primary_timeframe: 5m
        trend_timeframe: 1h
        max_spread_pct: 0.05
        enabled: false

      - symbol: XAU/USDT-PERP
        contract_type: futures_perpetual
        leverage: 5
        margin_type: isolated
        tick_size: 0.01
        lot_size: 0.1
        min_notional: 5.0
        max_order_notional: 50000.0
        max_position_size_pct: 3.0
        timeframes: [5m, 15m, 1h, 4h]
        primary_timeframe: 15m
        trend_timeframe: 4h
        max_spread_pct: 0.02
        enabled: true
